rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isBootstrapEmail() {
      return authEmail() == 'hariadirahmat2003@gmail.com'
        || authEmail() == 'scoutforestbest@gmail.com'
        || authEmail() == 'admin@gmail.com';
    }

    function isPrimaryProtectedAdminEmail(email) {
      return email.lower() == 'hariadirahmat2003@gmail.com'
        || email.lower() == 'scoutforestbest@gmail.com';
    }

    function isProtectedUsersDoc(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && isPrimaryProtectedAdminEmail(get(/databases/$(database)/documents/users/$(userId)).data.email);
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapEmail()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && getUserData().role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function preRegisteredExistsForAuth() {
      return exists(/databases/$(database)/documents/pre_registered/$(authEmail()));
    }

    function validOptionalPurnaProfileFields() {
      return (!('tanggalLahir' in incoming()) || (incoming().tanggalLahir is string && incoming().tanggalLahir.size() <= 10))
        && (!('alamat' in incoming()) || (incoming().alamat is string && incoming().alamat.size() <= 500))
        && (!('agama' in incoming()) || (incoming().agama is string && incoming().agama.size() <= 50))
        && (!('pendidikanSd' in incoming()) || (incoming().pendidikanSd is string && incoming().pendidikanSd.size() <= 120))
        && (!('pendidikanSmp' in incoming()) || (incoming().pendidikanSmp is string && incoming().pendidikanSmp.size() <= 120))
        && (!('pendidikanSma' in incoming()) || (incoming().pendidikanSma is string && incoming().pendidikanSma.size() <= 120))
        && (!('pendidikanKuliah' in incoming()) || (incoming().pendidikanKuliah is string && incoming().pendidikanKuliah.size() <= 120))
        && (!('statusPerkawinan' in incoming()) || (incoming().statusPerkawinan is string && incoming().statusPerkawinan.size() <= 30))
        && (!('profileComplete' in incoming()) || incoming().profileComplete is bool);
    }

    function validOptionalOnboardingFields() {
      return validOptionalPurnaProfileFields()
        && (!('namaDepan' in incoming()) || (incoming().namaDepan is string && incoming().namaDepan.size() <= 50))
        && (!('namaBelakang' in incoming()) || (incoming().namaBelakang is string && incoming().namaBelakang.size() <= 50))
        && (!('tempatLahir' in incoming()) || (incoming().tempatLahir is string && incoming().tempatLahir.size() <= 80))
        && (!('noHp' in incoming()) || (incoming().noHp is string && incoming().noHp.size() <= 20))
        && (!('tahunMasuk' in incoming()) || (incoming().tahunMasuk is string && incoming().tahunMasuk.size() == 4))
        && (!('membershipStatus' in incoming()) || incoming().membershipStatus in ['aktif', 'purna']);
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();

      allow create: if isSignedIn() && isValidId(userId) && (
        // Pembina bootstrap — first Google login creates own admin profile
        (isOwner(userId)
          && isBootstrapEmail()
          && incoming().userId == request.auth.uid
          && incoming().role == 'admin'
          && incoming().status == 'aktif'
          && incoming().email.lower() == authEmail()
          && incoming().nama is string && incoming().nama.size() > 0 && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && incoming().createdAt == request.time)
        ||
        // Pre-register migration on first login
        (isOwner(userId)
          && incoming().userId == request.auth.uid
          && incoming().email.lower() == authEmail()
          && incoming().role in ['anggota', 'admin', 'purna']
          && incoming().status in ['aktif', 'nonaktif']
          && incoming().nama is string && incoming().nama.size() > 0 && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && incoming().createdAt == request.time
          && validOptionalPurnaProfileFields()
          && preRegisteredExistsForAuth())
        ||
        isAdmin()
      );

      allow update: if isSignedIn() && isValidId(userId) && (
        (isOwner(userId)
          && existing().role in ['anggota', 'purna']
          && incoming().userId == existing().userId
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().email == existing().email
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly([
            'nama', 'namaDepan', 'namaBelakang', 'kelas', 'regu', 'tempatLahir',
            'tanggalLahir', 'alamat', 'agama', 'noHp', 'tahunMasuk', 'membershipStatus',
            'pendidikanSd', 'pendidikanSmp', 'pendidikanSma', 'pendidikanKuliah',
            'statusPerkawinan', 'profileComplete'
          ])
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && validOptionalOnboardingFields())
        ||
        (isOwner(userId)
          && existing().role == 'admin'
          && incoming().userId == existing().userId
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().email == existing().email
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['nama', 'kelas', 'regu'])
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30)
        || (isAdmin() && !isProtectedUsersDoc(userId))
        || (isAdmin()
          && isProtectedUsersDoc(userId)
          && incoming().userId == existing().userId
          && incoming().email == existing().email
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().createdAt == existing().createdAt)
      );

      allow delete: if isAdmin() && !isProtectedUsersDoc(userId);
    }

    function hasValidOptionalLocation() {
      return (incoming().latitude == null || incoming().latitude is number)
        && (incoming().longitude == null || incoming().longitude is number);
    }

    function geofenceAllowsOptionalLocation() {
      return !exists(/databases/$(database)/documents/settings/geofence)
        || get(/databases/$(database)/documents/settings/geofence).data.enabled != true;
    }

    function geofenceRequiresLocation() {
      return exists(/databases/$(database)/documents/settings/geofence)
        && get(/databases/$(database)/documents/settings/geofence).data.enabled == true
        && incoming().latitude is number
        && incoming().longitude is number;
    }

    function hasValidLocation() {
      return hasValidOptionalLocation()
        && (geofenceAllowsOptionalLocation() || geofenceRequiresLocation());
    }

    function validActiveCheckin(date, token) {
      return exists(/databases/$(database)/documents/settings/active_checkin)
        && get(/databases/$(database)/documents/settings/active_checkin).data.date == date
        && get(/databases/$(database)/documents/settings/active_checkin).data.token == token
        && get(/databases/$(database)/documents/settings/active_checkin).data.active == true;
    }

    // ── Attendance ─────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      // Izinkan get dokumen belum ada (cek duplikat sebelum create)
      allow get: if isSignedIn() && (
        !exists(/databases/$(database)/documents/attendance/$(attendanceId))
        || resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && isValidId(attendanceId) && (
        (incoming().userId == request.auth.uid
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().tanggal is string && incoming().tanggal.size() == 10
          && incoming().qrToken is string && incoming().qrToken.size() <= 100
          && incoming().status == 'hadir'
          && hasValidLocation()
          && incoming().timestamp == request.time
          && validActiveCheckin(incoming().tanggal, incoming().qrToken))
        || isAdmin()
      );

      allow update, delete: if isAdmin();
    }

    // ── QR Codes ───────────────────────────────────────────────────────────
    match /qr_codes/{date} {
      allow read, write: if isAdmin();
    }

    // ── Settings ───────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Pre-registration ───────────────────────────────────────────────────
    match /pre_registered/{email} {
      allow get: if isAdmin() || (isSignedIn() && authEmail() == email.lower());
      allow list: if isAdmin();
      allow create, update: if isAdmin()
        && (!isPrimaryProtectedAdminEmail(email) || incoming().role == 'admin');
      allow delete: if (isAdmin() && !isPrimaryProtectedAdminEmail(email))
        || (isSignedIn() && authEmail() == email.lower());
    }

    function validMemberRegistrationFields(regEmail) {
      return incoming().email.lower() == regEmail.lower()
        && incoming().nama is string && incoming().nama.size() > 0 && incoming().nama.size() <= 100
        && incoming().approvalStatus == 'pending'
        && incoming().submittedAt == request.time
        && incoming().keys().hasOnly([
          'email', 'nama', 'approvalStatus', 'submittedAt'
        ]);
    }

    function memberNotPreRegistered(email) {
      return !exists(/databases/$(database)/documents/pre_registered/$(email.lower()));
    }

    function registrationDocPath(email) {
      return /databases/$(database)/documents/purna_registrations/$(email.lower());
    }

    // ── Pendaftaran akun baru (halaman Register, tanpa login) ──────────────
    match /purna_registrations/{email} {
      // Izinkan cek email baru (doc belum ada) + status pending/rejected/approved
      allow get: if isAdmin()
        || (isSignedIn() && authEmail() == email.lower())
        || !exists(registrationDocPath(email))
        || (resource.data.approvalStatus in ['pending', 'rejected', 'approved']);
      allow list: if isAdmin();
      allow create: if memberNotPreRegistered(email)
        && !exists(registrationDocPath(email))
        && validMemberRegistrationFields(email);
      allow update: if isAdmin()
        || (resource.data.approvalStatus == 'rejected'
          && incoming().approvalStatus == 'pending'
          && memberNotPreRegistered(email)
          && validMemberRegistrationFields(email));
      allow delete: if isAdmin() && !isPrimaryProtectedAdminEmail(email);
    }

    // ── Deny everything else (must be last) ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isBootstrapEmail() {
      return request.auth.token.email == 'hariadirahmat2003@gmail.com'
        || request.auth.token.email == 'admin@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapEmail()
        || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && getUserData().role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();

      allow create: if isSignedIn() && isValidId(userId) && (
        // Anggota self-register
        (isOwner(userId)
          && incoming().userId == request.auth.uid
          && incoming().role == 'anggota'
          && incoming().status == 'aktif'
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().email == request.auth.token.email
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && incoming().createdAt == request.time)
        ||
        // Pembina bootstrap — first Google login creates own admin profile
        (isOwner(userId)
          && isBootstrapEmail()
          && incoming().userId == request.auth.uid
          && incoming().role == 'admin'
          && incoming().status == 'aktif'
          && incoming().email == request.auth.token.email
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && incoming().createdAt == request.time)
        ||
        // Pre-register migration on first login
        (isOwner(userId)
          && incoming().userId == request.auth.uid
          && incoming().email == request.auth.token.email
          && incoming().role in ['anggota', 'admin']
          && incoming().status in ['aktif', 'nonaktif']
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30
          && incoming().createdAt == request.time
          && exists(/databases/$(database)/documents/pre_registered/$(request.auth.token.email)))
        ||
        isAdmin()
      );

      allow update: if isSignedIn() && isValidId(userId) && (
        (isOwner(userId)
          && incoming().userId == existing().userId
          && incoming().role == existing().role
          && incoming().status == existing().status
          && incoming().email == existing().email
          && incoming().createdAt == existing().createdAt
          && incoming().diff(existing()).affectedKeys().hasOnly(['nama', 'kelas', 'regu'])
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().kelas is string && incoming().kelas.size() <= 20
          && incoming().regu is string && incoming().regu.size() <= 30)
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    function hasValidOptionalLocation() {
      return (incoming().latitude == null || incoming().latitude is number)
        && (incoming().longitude == null || incoming().longitude is number);
    }

    function validActiveCheckin(date, token) {
      return exists(/databases/$(database)/documents/settings/active_checkin)
        && get(/databases/$(database)/documents/settings/active_checkin).data.date == date
        && get(/databases/$(database)/documents/settings/active_checkin).data.token == token
        && get(/databases/$(database)/documents/settings/active_checkin).data.active == true;
    }

    // ── Attendance ─────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      // Izinkan get dokumen belum ada (cek duplikat sebelum create)
      allow get: if isSignedIn() && (
        !exists(/databases/$(database)/documents/attendance/$(attendanceId))
        || resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      allow create: if isSignedIn() && isValidId(attendanceId) && (
        (incoming().userId == request.auth.uid
          && incoming().nama is string && incoming().nama.size() <= 100
          && incoming().tanggal is string && incoming().tanggal.size() == 10
          && incoming().qrToken is string && incoming().qrToken.size() <= 100
          && incoming().status == 'hadir'
          && hasValidOptionalLocation()
          && incoming().timestamp == request.time
          && validActiveCheckin(incoming().tanggal, incoming().qrToken))
        || isAdmin()
      );

      allow update, delete: if isAdmin();
    }

    // ── QR Codes ───────────────────────────────────────────────────────────
    match /qr_codes/{date} {
      allow read, write: if isAdmin();
    }

    // ── Settings ───────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── Pre-registration ───────────────────────────────────────────────────
    match /pre_registered/{email} {
      allow get: if isSignedIn() && request.auth.token.email == email;
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && request.auth.token.email == email);
    }

    // ── Deny everything else (must be last) ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
